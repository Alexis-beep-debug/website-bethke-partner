---
import BaseLayout from '../layouts/BaseLayout.astro';
const calUrl = "https://calendar.app.google/9B63foKnMQroLAKM9";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "B2B Leadrecherche, Anreicherung & Scoring",
  "provider": {
    "@type": "ProfessionalService",
    "@id": "https://www.bethke-und-partner.de/#organization"
  },
  "description": "DSGVO-konforme B2B-Leadrecherche mit Datenanreicherung und Scoring nach Kaufsignalen. Für telefonische Kaltakquise, Direktmailing und E-Mail-Outbound.",
  "areaServed": { "@type": "Country", "name": "DE" },
  "serviceType": ["Lead Scoring", "Leadrecherche", "Datenanreicherung", "B2B Lead Generation"],
  "offers": [
    {
      "@type": "Offer",
      "name": "Testpaket",
      "price": "0.75",
      "priceCurrency": "EUR",
      "description": "500 Kontakte einmalig — ICP und Scoring-Faktoren prüfen"
    },
    {
      "@type": "Offer",
      "name": "1.000 Kontakte / Monat",
      "price": "0.55",
      "priceCurrency": "EUR",
      "description": "Pro Kontakt — laufende Lieferung mit Scoring und Anreicherung"
    },
    {
      "@type": "Offer",
      "name": "2.500 Kontakte / Monat",
      "price": "0.42",
      "priceCurrency": "EUR",
      "description": "Pro Kontakt — inkl. priorisiertes Scoring, LinkedIn, Postadresse"
    }
  ]
};
---

<BaseLayout
  title="Leadrecherche, Anreicherung & Scoring | Bethke & Partner"
  description="Wir recherchieren, anreichern und scoren Ihre B2B-Zielkontakte — DSGVO-konform. Sie sprechen nur mit Firmen, die gerade Kaufsignale zeigen. Für Kaltakquise, Direktmailing und E-Mail-Outbound."
  activePage=""
  ogTitle="B2B Leadrecherche & Scoring — ab 0,35 € pro Kontakt"
  ogDescription="DSGVO-konforme Leadrecherche mit Scoring nach Kaufsignalen. Für Kaltakquise, Direktmailing und E-Mail-Outbound."
  structuredData={structuredData}
>

<!-- HERO -->
<div class="ls-hero">
  <div class="ls-inner">
    <div class="ls-tag"><span class="ls-tag-line"></span> Leadrecherche &amp; Scoring</div>
    <h1 class="ls-h1">70 % weniger Kosten.<br><em>Bessere Kontakte.</em></h1>
    <p class="ls-sub">Für Marketing-Agenturen, die neue Kunden gewinnen wollen: Wir suchen die Firmen, die zu Ihrem Angebot passen, finden den richtigen Ansprechpartner und prüfen, ob es gerade einen Grund gibt, sie anzurufen.</p>
    <div class="ls-actions">
      <a href={calUrl} target="_blank" rel="noopener" class="btn-primary">Erstgespräch vereinbaren</a>
    </div>
  </div>

  <!-- ANIMATED LEAD CARD FEED -->
  <div class="lead-card-visual">
    <div class="lc-feed">
      <!-- Toast notification -->
      <div class="lc-toast" id="lcToast">
        <div class="lc-toast-dot"></div>
        Neuer Lead
      </div>

      <!-- Card container -->
      <div class="lc-stack" id="lcStack">
        <!-- Cards get injected by JS -->
      </div>
    </div>
  </div>

  <script is:inline>
  (function() {
    const leads = [
      {
        initials: 'DT', name: 'datacraft GmbH', meta: 'IT-Dienstleister · 45 MA · München',
        contact: 'Thomas Meier', role: 'Geschäftsführer',
        phone: '+49 176 ••• •• 41', email: 't.meier@datacraft.de', linkedin: 'linkedin.com/in/tmeier',
        triggers: ['Sucht Senior DevOps Engineer', 'Funding-Runde Q1 2026', 'Neuer CTO seit Februar'],
        score: 92, grade: 'A'
      },
      {
        initials: 'NV', name: 'Noviq Solutions', meta: 'SaaS · 28 MA · Berlin',
        contact: 'Laura Engel', role: 'Head of Marketing',
        phone: '+49 151 ••• •• 88', email: 'l.engel@noviq.io', linkedin: 'linkedin.com/in/lengel',
        triggers: ['Sucht Marketing Manager', 'Serie-A abgeschlossen', 'Neue Website gelauncht'],
        score: 87, grade: 'A'
      },
      {
        initials: 'CP', name: 'CloudPilot AG', meta: 'Cloud Services · 120 MA · Hamburg',
        contact: 'Stefan Braun', role: 'VP Sales',
        phone: '+49 170 ••• •• 23', email: 's.braun@cloudpilot.de', linkedin: 'linkedin.com/in/sbraun',
        triggers: ['3 Sales-Stellen offen', 'Neuer Standort Frankfurt', 'CRM-Migration auf HubSpot'],
        score: 95, grade: 'A'
      },
      {
        initials: 'FM', name: 'finmatch GmbH', meta: 'FinTech · 35 MA · Stuttgart',
        contact: 'Anna Richter', role: 'Geschäftsführerin',
        phone: '+49 162 ••• •• 67', email: 'a.richter@finmatch.de', linkedin: 'linkedin.com/in/arichter',
        triggers: ['Sucht Head of Growth', 'Seed+ Runde Q4 2025', 'Wettbewerber-Wechsel bei Kunden'],
        score: 84, grade: 'A'
      }
    ];

    const stack = document.getElementById('lcStack');
    const toast = document.getElementById('lcToast');
    if (!stack || !toast) return;

    let index = 0;

    function buildCard(lead) {
      return `
        <div class="lc lc-enter">
          <div class="lc-header">
            <div class="lc-avatar">${lead.initials}</div>
            <div class="lc-company">
              <div class="lc-name">${lead.name}</div>
              <div class="lc-meta">${lead.meta}</div>
            </div>
            <div class="lc-badge lc-badge-pop">${lead.grade}</div>
          </div>
          <div class="lc-section">
            <div class="lc-section-label">Ansprechpartner</div>
            <div class="lc-contact-name">${lead.contact}</div>
            <div class="lc-contact-role">${lead.role}</div>
          </div>
          <div class="lc-details">
            <div class="lc-detail">
              <span class="lc-detail-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.81.36 1.6.68 2.34a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.74.32 1.53.55 2.34.68a2 2 0 0 1 1.72 2.03z"/></svg></span>
              ${lead.phone}
            </div>
            <div class="lc-detail">
              <span class="lc-detail-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></span>
              ${lead.email}
            </div>
            <div class="lc-detail">
              <span class="lc-detail-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg></span>
              ${lead.linkedin}
            </div>
          </div>
          <div class="lc-section">
            <div class="lc-section-label">Trigger-Signale</div>
            <div class="lc-triggers">
              ${lead.triggers.map(t => `<div class="lc-trigger"><span class="lc-trigger-check">✓</span> ${t}</div>`).join('')}
            </div>
          </div>
          <div class="lc-score-section">
            <div class="lc-section-label">Lead Score</div>
            <div class="lc-score-bar-bg">
              <div class="lc-score-bar" style="animation:lcFill 1s 0.3s cubic-bezier(0.16,1,0.3,1) forwards; --fill-width:${lead.score}%"></div>
            </div>
            <div class="lc-score-row">
              <span class="lc-score-val">${lead.score} / 100</span>
              <span class="lc-icp-tag">ICP Fit</span>
            </div>
          </div>
        </div>`;
    }

    function showCard() {
      const lead = leads[index % leads.length];

      // Show toast
      toast.classList.remove('lc-toast-show');
      void toast.offsetWidth;
      toast.classList.add('lc-toast-show');

      // Crossfade: start exit, then overlap with new card
      const oldCard = stack.querySelector('.lc:not(.lc-exit)');
      if (oldCard) {
        oldCard.classList.remove('lc-enter');
        oldCard.classList.add('lc-exit');
        setTimeout(() => oldCard.remove(), 1000);
      }

      // New card glides in while old one glides out
      setTimeout(() => {
        stack.insertAdjacentHTML('beforeend', buildCard(lead));
      }, 200);

      index++;
    }

    // Initial card after page load
    setTimeout(showCard, 800);
    // Loop every 5 seconds
    setInterval(showCard, 5000);
  })();
  </script>
</div>

<!-- FÜR WEN -->
<section class="alt">
  <div class="ls-wrap">
    <h2 class="ls-h2 r">Für Marketing-Agenturen, die Outbound ernst meinen</h2>
    <div class="icp-card-single r">
      <p>Sie sind eine Marketing-Agentur und gewinnen Neukunden über Kaltakquise, Direktmailing oder E-Mail-Outbound — oder Sie wollen genau damit anfangen. Sie wissen: Ohne gute Kontaktdaten funktioniert keiner dieser Kanäle. Aber woher kommen die Daten?</p>
    </div>
    <h3 class="ls-h3 r">So machen es die meisten heute:</h3>
    <div class="today-grid r">
      <div class="today-item">
        <div class="today-check">✗</div>
        <div>
          <h4>Listen kaufen bei North Data, Cognism oder Dealfront</h4>
          <p>Sie zahlen 1–2 € pro Kontakt für Massenlisten. Firmendaten stimmen meistens — aber ob die Firma gerade Bedarf hat, weiß niemand. Keine Kaufsignale, kein Scoring, viele tote Nummern.</p>
        </div>
      </div>
      <div class="today-item">
        <div class="today-check">✗</div>
        <div>
          <h4>Mitarbeiter recherchieren lassen</h4>
          <p>Eine Teilzeitkraft oder ein Werkstudent googelt Firmen, sucht Ansprechpartner bei LinkedIn und trägt alles in eine Tabelle ein. Langsam, teuer und ohne systematische Qualitätskontrolle.</p>
        </div>
      </div>
      <div class="today-item">
        <div class="today-check">✗</div>
        <div>
          <h4>Vertriebler recherchieren selbst</h4>
          <p>Ihre Closer oder SDRs verbringen die halbe Zeit damit, Kontakte zusammenzusuchen, statt zu telefonieren. Sie bezahlen Vertriebsgehälter für Recherche-Arbeit.</p>
        </div>
      </div>
      <div class="today-item">
        <div class="today-check">✗</div>
        <div>
          <h4>LinkedIn Sales Navigator</h4>
          <p>Gut zum Filtern, aber keine Telefonnummern, keine E-Mails, kein Scoring. Am Ende kopieren Sie trotzdem alles per Hand in eine Excel.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- WARUM LEAD-QUALITÄT DER GRÖSSTE HEBEL IST -->
<section>
  <div class="ls-wrap">
    <h2 class="ls-h2 r">Das Problem: Ihr Team recherchiert, statt zu telefonieren</h2>
    <p class="ls-lead r" style="margin-top:0; margin-bottom:40px;">In den meisten Vertriebsteams verbringen die Leute die Hälfte ihrer Zeit damit, Kontakte zu suchen, Nummern rauszufinden und Firmen zu prüfen. Die andere Hälfte telefonieren sie — mit einer Liste, die zur Hälfte nicht passt. Das Ergebnis:</p>
    <div class="lever-grid r">
      <div class="lever-card lever-bad">
        <div class="lever-label">Schlechte Daten</div>
        <div class="lever-stat">1–2</div>
        <div class="lever-desc">Termine aus 100 Anrufen. Falsche Ansprechpartner, kein Bedarf, veraltete Nummern. Gleiche Gesprächsqualität, aber kaum Ergebnis.</div>
      </div>
      <div class="lever-arrow">→</div>
      <div class="lever-card lever-good">
        <div class="lever-label">Gute Daten</div>
        <div class="lever-stat">5–10</div>
        <div class="lever-desc">Termine aus 100 Anrufen. Richtiger Ansprechpartner, aktueller Bedarf, geprüfte Nummer. Gleiche Gesprächsqualität — aber drei- bis fünfmal mehr Ergebnis.</div>
      </div>
    </div>
    <p class="ls-lead r">Wir übernehmen die Recherche, damit Ihr Team die volle Zeit am Telefon verbringt — und zwar mit den richtigen Leuten.</p>
  </div>
</section>

<!-- WAS WIR MACHEN -->
<section>
  <div class="ls-wrap">
    <h2 class="ls-h2 r">Was wir für Sie tun</h2>
    <div class="process-flow r stagger">
      <div class="pf-step">
        <div class="pf-num">01</div>
        <h3 class="pf-title">Recherche</h3>
        <p class="pf-body">Wir suchen Firmen, die zu Ihrem Angebot passen — nach Branche, Größe, Region und Struktur. Keine Massenliste aus einer Datenbank, sondern einzeln geprüft.</p>
      </div>
      <div class="pf-step">
        <div class="pf-num">02</div>
        <h3 class="pf-title">Anreicherung</h3>
        <p class="pf-body">Zu jeder Firma finden wir den richtigen Ansprechpartner: Name, Position, direkte E-Mail, Telefonnummer, LinkedIn. Geprüft, nicht geraten.</p>
      </div>
      <div class="pf-step">
        <div class="pf-num">03</div>
        <h3 class="pf-title">Scoring</h3>
        <p class="pf-body">Wir prüfen, ob es gerade einen konkreten Grund gibt, die Firma anzusprechen — z.B. offene Stellen, neues Management oder Wachstum. Nur wer wirklich passt, kommt auf die Liste.</p>
      </div>
      <div class="pf-step">
        <div class="pf-num">04</div>
        <h3 class="pf-title">Übergabe</h3>
        <p class="pf-body">Sie bekommen eine sortierte Liste — die vielversprechendsten Kontakte oben. Als CSV, Excel oder direkt in Ihr CRM.</p>
      </div>
    </div>
  </div>
</section>

<!-- TRIGGER-SIGNALE -->
<section class="alt">
  <div class="ls-wrap">
    <h2 class="ls-h2 r">Woran wir erkennen, dass eine Firma gerade passt</h2>
    <p class="ls-lead r">Nicht jede Firma auf einer Liste hat gerade Bedarf. Wir prüfen konkrete Signale, die zeigen, dass sich bei einer Firma etwas tut — und dass Ihr Angebot gerade relevant sein könnte.</p>
    <div class="trigger-grid r stagger">
      <div class="trigger-card">
        <div class="trigger-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="18" rx="2"/><path d="M8 7h8M8 11h5"/></svg>
        </div>
        <h4>Stellenanzeigen</h4>
        <p>Eine Firma sucht einen Head of Sales oder stellt Vertriebler ein? Dann wächst sie — und braucht wahrscheinlich Unterstützung dabei.</p>
      </div>
      <div class="trigger-card">
        <div class="trigger-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        </div>
        <h4>Technologie-Wechsel</h4>
        <p>Die Firma hat gerade ein neues CRM eingeführt oder migriert in die Cloud? Solche Umstellungen erzeugen konkreten Bedarf an Dienstleistungen.</p>
      </div>
      <div class="trigger-card">
        <div class="trigger-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
        </div>
        <h4>Frisches Kapital</h4>
        <p>Nach einer Finanzierungsrunde wird investiert. Firmen mit frischem Geld treffen Entscheidungen schneller und haben Budget für neue Dienstleister.</p>
      </div>
      <div class="trigger-card">
        <div class="trigger-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <h4>Neue Leute in der Führung</h4>
        <p>Ein neuer Geschäftsführer oder Vertriebsleiter bringt neue Prioritäten mit. In den ersten Monaten werden Dienstleister gewechselt und Budgets neu verteilt.</p>
      </div>
      <div class="trigger-card">
        <div class="trigger-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>
        </div>
        <h4>Wachstum</h4>
        <p>Neue Standorte, mehr Mitarbeiter, Pressemeldungen über Expansion — Firmen, die wachsen, haben Budget und brauchen Unterstützung.</p>
      </div>
      <div class="trigger-card">
        <div class="trigger-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        </div>
        <h4>Auslaufende Verträge</h4>
        <p>Wenn ein bestehender Vertrag mit einem Wettbewerber ausläuft, ist die Firma offen für Alternativen. Wir finden den richtigen Zeitpunkt.</p>
      </div>
    </div>
  </div>
</section>

<!-- WIE LEAD SCORING FUNKTIONIERT -->
<section>
  <div class="ls-wrap">
    <h2 class="ls-h2 r">Wie unser Lead Scoring funktioniert</h2>
    <div class="scoring-example r">
      <div class="score-header">
        <div class="score-label">Beispiel: Lead Score für eine Marketing-Agentur, die SaaS-Kunden sucht</div>
      </div>
      <div class="score-table">
        <div class="score-row">
          <span class="score-signal">SaaS-Firma, 20–200 Mitarbeiter, DACH-Region</span>
          <span class="score-points">+30 Punkte</span>
        </div>
        <div class="score-row">
          <span class="score-signal">Stellenanzeige: sucht Marketing Manager</span>
          <span class="score-points">+20 Punkte</span>
        </div>
        <div class="score-row">
          <span class="score-signal">Frische Finanzierung in den letzten 6 Monaten</span>
          <span class="score-points">+15 Punkte</span>
        </div>
        <div class="score-row">
          <span class="score-signal">Neuer Head of Marketing seit 2 Monaten</span>
          <span class="score-points">+15 Punkte</span>
        </div>
        <div class="score-row">
          <span class="score-signal">Webseite zeigt: keine aktive Paid-Ads-Strategie</span>
          <span class="score-points">+10 Punkte</span>
        </div>
        <div class="score-row">
          <span class="score-signal">Entscheider auf LinkedIn gefunden</span>
          <span class="score-points">+10 Punkte</span>
        </div>
        <div class="score-row score-total">
          <span class="score-signal">Gesamt</span>
          <span class="score-points">100 / 100</span>
        </div>
      </div>
      <div class="score-tiers">
        <div class="tier tier-a"><span class="tier-badge">A</span> 80–100: Sofort kontaktieren</div>
        <div class="tier tier-b"><span class="tier-badge tier-badge-b">B</span> 50–79: In Sequenz aufnehmen</div>
        <div class="tier tier-c"><span class="tier-badge tier-badge-c">C</span> &lt; 50: Nicht kontaktieren</div>
      </div>
    </div>
    <p class="ls-note r">Das Scoring-Modell passen wir für jeden Kunden an. Die Trigger und Gewichtungen hängen von Ihrem Markt, Ihrem Angebot und Ihrer Zielgruppe ab.</p>
  </div>
</section>

<!-- DSGVO -->
<section class="alt">
  <div class="ls-wrap">
    <h2 class="ls-h2 r">Datenschutz: So arbeiten wir</h2>
    <div class="gdpr-grid r stagger">
      <div class="gdpr-card">
        <h4>Nur öffentliche Daten</h4>
        <p>Wir arbeiten ausschließlich mit öffentlich zugänglichen Informationen — Unternehmenswebseiten, Handelsregister, LinkedIn-Profile, Stellenportale. Keine gekauften Privatdaten.</p>
      </div>
      <div class="gdpr-card">
        <h4>Rechtliche Grundlage</h4>
        <p>Geschäftskontakte im B2B-Bereich dürfen über das berechtigte Interesse (Art. 6 DSGVO) angesprochen werden. Das gilt für Telefon, Post und E-Mail gleichermaßen.</p>
      </div>
      <div class="gdpr-card">
        <h4>Opt-Out jederzeit</h4>
        <p>Jeder Kontakt kann sich jederzeit abmelden. Wir führen eine zentrale Sperrliste und stellen sicher, dass kein Kontakt doppelt angesprochen wird.</p>
      </div>
      <div class="gdpr-card">
        <h4>Dokumentation &amp; Löschfristen</h4>
        <p>Alle Datenquellen und Verarbeitungsschritte sind dokumentiert. Nicht konvertierte Kontakte werden nach vereinbarter Frist gelöscht.</p>
      </div>
    </div>
  </div>
</section>

<!-- USE CASES -->
<section>
  <div class="ls-wrap">
    <h2 class="ls-h2 r">Fertige Listen — egal wie Sie akquirieren</h2>
    <p class="ls-lead r">Ob Sie anrufen, Briefe verschicken oder E-Mails schreiben: Wir liefern die Daten so, wie Sie sie brauchen.</p>
    <div class="channel-grid r stagger">
      <div class="channel-card">
        <div class="channel-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.81.36 1.6.68 2.34a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.74.32 1.53.55 2.34.68a2 2 0 0 1 1.72 2.03z"/></svg>
        </div>
        <h4>Telefonische Kaltakquise</h4>
        <p>Direkte Durchwahlen und der Name der Person, die entscheidet. Sortiert — die besten Kontakte stehen oben.</p>
      </div>
      <div class="channel-card">
        <div class="channel-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </div>
        <h4>E-Mail</h4>
        <p>Geprüfte geschäftliche E-Mail-Adressen. Dazu Kontext zur Firma, damit Sie keine Standardmail schreiben müssen.</p>
      </div>
      <div class="channel-card">
