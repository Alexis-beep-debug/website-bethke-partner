          <path d="M0,250 L40,250 L40,200 L55,200 L55,180 L65,180 L65,200 L80,200 L80,250 L120,250 L120,210 L130,210 L130,190 L140,160 L150,190 L160,210 L170,210 L170,250 L200,250 L200,180 L210,180 L210,160 L215,130 L220,110 L225,130 L230,160 L240,160 L240,180 L250,180 L250,250 L280,250 L280,220 L290,220 L290,200 L300,200 L300,170 L305,140 L310,120 L315,100 L320,80 L325,100 L330,120 L335,140 L340,170 L340,200 L350,200 L350,220 L360,220 L360,250 L390,250 L390,190 L395,170 L400,150 L405,130 L410,110 L412,90 L414,70 L416,60 L418,70 L420,90 L422,110 L425,130 L430,150 L435,170 L440,190 L440,250 L470,250 L470,195 L480,195 L480,175 L485,155 L490,140 L495,155 L500,175 L510,175 L510,195 L520,195 L520,250 L550,250 L550,210 L560,210 L560,195 L570,195 L570,180 L580,180 L580,195 L590,195 L590,210 L600,210 L600,250 L630,250 L630,220 L640,220 L640,205 L645,190 L650,175 L655,190 L660,205 L670,205 L670,220 L680,220 L680,250 L710,250 L710,230 L720,230 L720,215 L730,215 L730,230 L740,230 L740,250 L800,250" stroke="rgba(107,133,160,0.18)" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="320" cy="76" r="3" fill="rgba(107,133,160,0.15)"/>
          <circle cx="416" cy="56" r="3" fill="rgba(107,133,160,0.15)"/>
        </svg>
      </div>
    </div>

    <!-- Title bottom -->
    <h2 class="hero-title hero-title-bottom" id="heroTitleBottom">
      <em>Vertriebsagentur</em> <span class="light">aus Nürnberg.</span>
    </h2>

    <!-- Scroll hint -->
    <div class="hero-scroll-hint" id="heroScrollHint">
      <div class="hero-scroll-line"></div>
    </div>
  </div>
</div>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const section = document.getElementById('heroScroll');
  const card = document.getElementById('heroCard');
  const titleTop = document.getElementById('heroTitleTop');
  const titleBottom = document.getElementById('heroTitleBottom');
  const scrollHint = document.getElementById('heroScrollHint');

  if (section && card && titleTop && titleBottom) {
    const isMobile = () => window.innerWidth < 768;
    const startScale = () => isMobile() ? 0.85 : 0.6;

    const immerseScale = () => {
      const vw = window.innerWidth;
      const vh = window.innerHeight;
      const cardW = Math.min(vw * 0.88, 680);
      const cardH = Math.min(vh * 0.56, 480);
      if (cardW <= 0 || cardH <= 0) return 2;
      return Math.max(vw / cardW, vh / cardH) * 1.08;
    };

    // Initial state
    gsap.set(card, { scale: startScale(), transformOrigin: '50% 50%' });

    // Entry animation
    const entry = gsap.timeline({ delay: 0.2 });
    entry.from(titleTop, { opacity: 0, y: 40, duration: 1, ease: 'expo.out' }, 0);
    entry.from(titleBottom, { opacity: 0, y: -40, duration: 1, ease: 'expo.out' }, 0.12);
    entry.from(card, { opacity: 0, scale: startScale() * 0.9, duration: 1.2, ease: 'power3.out' }, 0.25);
    entry.from(scrollHint, { opacity: 0, duration: 0.8 }, 1);

    // Scroll choreography
    const master = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: 'top top',
        end: 'bottom bottom',
        scrub: 0.5,
        invalidateOnRefresh: true,
      }
    });

    // Phase 1 (0–0.15): Card scales to 1, titles start splitting
    master.to(card, { scale: 1, ease: 'power2.out', duration: 0.15 }, 0);
    master.to(scrollHint, { opacity: 0, duration: 0.05 }, 0);
    master.to(titleTop, {
      x: () => isMobile() ? '-70vw' : '-55vw',
      letterSpacing: '0.02em',
      ease: 'power2.inOut',
      duration: 0.15,
    }, 0);
    master.to(titleBottom, {
      x: () => isMobile() ? '70vw' : '55vw',
      letterSpacing: '0.02em',
      ease: 'power2.inOut',
      duration: 0.15,
    }, 0);

    // Phase 2 (0.15–0.65): Card scales to immersive fullscreen, titles fade
    master.to(card, {
      scale: immerseScale,
      ease: 'power2.in',
      duration: 0.5,
    }, 0.15);
    master.to(titleTop, { opacity: 0, ease: 'power1.in', duration: 0.15 }, 0.15);
    master.to(titleBottom, { opacity: 0, ease: 'power1.in', duration: 0.15 }, 0.15);

    // Phase 3 (0.65–0.78): Hold immersive
    // (implicit — no changes)

    // Phase 4 (0.78–1.0): Card scales back, titles return
    master.to(card, { scale: startScale, ease: 'power3.inOut', duration: 0.22 }, 0.78);
    master.to(titleTop, {
      x: 0, opacity: 1, letterSpacing: '-0.04em',
      ease: 'power2.inOut', duration: 0.22,
    }, 0.78);
    master.to(titleBottom, {
      x: 0, opacity: 1, letterSpacing: '-0.04em',
      ease: 'power2.inOut', duration: 0.22,
    }, 0.78);

    ScrollTrigger.refresh();
  }
</script>

