---
import BaseLayout from '../layouts/BaseLayout.astro';

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "url": "https://www.bethke-und-partner.de/fallstudien",
  "name": "Fallstudien – Nachgewiesene Ergebnisse",
  "description": "Konkrete Fallstudien aus der B2B-Vertriebspraxis von Bethke & Partner.",
  "inLanguage": "de-DE"
};
---

<BaseLayout
  title="Fallstudien – Nachgewiesene Ergebnisse | Bethke & Partner"
  description="Konkrete Ergebnisse aus der Praxis: Wie Bethke & Partner für eine B2B-Marketingagentur 2,2 Mio. € Neukundenumsatz in 24 Monaten generierte."
  activePage="fallstudien"
  navVariant="minimal"
  structuredData={structuredData}
>

<!-- PAGE HEADER -->
<div class="page-header">
  <div class="page-header-inner">
    <div class="ph-label">
      <span>Fallstudien</span>
    </div>
    <h1 class="ph-h1">Ergebnisse, die<br><em>für sich sprechen.</em></h1>
    <p class="ph-sub">Eine Auswahl an Projekten, die unsere Expertise im Aufbau und in der Skalierung von B2B-Vertriebsstrukturen demonstrieren – für Agenturen, Beratungen und Dienstleister.</p>
    <div class="ph-stats">
      <div class="ph-stat">
        <div class="ph-stat-val">2,2 <em>Mio. €</em></div>
        <div class="ph-stat-label">Neukundenumsatz · Referenzprojekt</div>
      </div>
      <div class="ph-stat">
        <div class="ph-stat-val">400 <em>+</em></div>
        <div class="ph-stat-label">Opportunities · Referenzprojekt</div>
      </div>
      <div class="ph-stat">
        <div class="ph-stat-val">100 <em>+</em></div>
        <div class="ph-stat-label">Generierte Neukunden</div>
      </div>
    </div>
  </div>
</div>

<!-- FEATURED CASE: INTRO BAND -->
<div class="case-intro-band">
  <div class="case-intro-inner">
    <div class="case-intro-left r">
      <div class="case-tag">
        <span class="case-tag-dot"></span>
        Detaillierte Fallstudie · Marketing & Beratung
      </div>
      <h2 class="case-name">Von der Inhaber-Abhängigkeit<br>zur <em>skalierbaren Vertriebsstruktur.</em></h2>
      <p class="case-desc">Wie eine B2B-Marketing- und Beratungsagentur innerhalb von 24 Monaten ihr Neukundengeschäft professionalisierte, den Geschäftsführer aus dem operativen Vertrieb herauslöste – und dabei signifikant skalierte.</p>
    </div>
    <div class="case-intro-right r d2">
      <div class="kpi-grid-dark">
        <div class="kd">
          <div class="kd-val">2,2 <em>Mio.</em></div>
          <div class="kd-label">Neukundenumsatz<br>über 24 Monate</div>
        </div>
        <div class="kd">
          <div class="kd-val">400 <em>+</em></div>
          <div class="kd-label">Qualifizierte Opportunities<br>generiert</div>
        </div>
        <div class="kd">
          <div class="kd-val">100 <em>+</em></div>
          <div class="kd-label">Neukunden<br>gewonnen</div>
        </div>
        <div class="kd">
          <div class="kd-val">5 <em>Mo.</em></div>
          <div class="kd-label">Stabile Ramp-up-Zeit<br>neue Vertriebler</div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- CASE BODY -->
<div class="case-body-section">
  <div class="case-body-inner">

    <!-- Ausgangssituation -->
    <div class="situation-layout r">
      <div>
        <div class="situation-label">Ausgangssituation</div>
        <h3 class="situation-h">Ein Vertrieb, der am<br><em>Geschäftsführer hing.</em></h3>
        <p class="situation-body">Der Geschäftsführer generierte über 80 % des Umsatzes selbst und war tief im operativen Vertrieb gebunden. Frühere Versuche, ein Vertriebsteam aufzubauen, scheiterten an hoher Fluktuation und schwankender Performance – mit erheblichem Stress auf der Führungsebene als Folge.</p>
      </div>
      <div>
        <div class="situation-label">Konkrete Herausforderungen</div>
        <ul class="challenge-list">
          <li class="challenge-item">
            <span class="challenge-num">01</span>
            <span>Keine Prozesse, keine Skalierbarkeit: Jeder Vertriebler arbeitete nach eigenem Stil – ohne Vorlage, ohne ICP-Schärfung, ohne messbares System.</span>
          </li>
          <li class="challenge-item">
            <span class="challenge-num">02</span>
            <span>Single Point of Failure: 80 % des Umsatzes hingen an einer einzigen Person – Urlaub, Krankheit oder Abgang hätten das Unternehmen unmittelbar getroffen.</span>
          </li>
          <li class="challenge-item">
            <span class="challenge-num">03</span>
            <span>Hohe Fluktuation, langsames Onboarding: Neue Vertriebler wurden nicht schnell produktiv – und verließen das Unternehmen häufig noch in der Einarbeitung.</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Maßnahmen -->
    <div class="massnahmen-section r">
      <div class="situation-label">Durchgeführte Maßnahmen</div>
      <h3 class="situation-h">Systematisch. <em>Nicht intuitiv.</em></h3>
      <div class="massnahmen-grid">
        <div class="m-card">
          <div class="m-card-num">01</div>
          <div class="m-card-title">ICP-Schärfung & Positionierung</div>
          <p class="m-card-body">Präzise Definition des Ideal Customer Profile auf Basis der profitabelsten Bestandskunden – welche Branchen, Unternehmensgrößen und Entscheider bringen den höchsten ROI.</p>
        </div>
        <div class="m-card">
          <div class="m-card-num">02</div>
          <div class="m-card-title">Vertriebskommunikation & Scripting</div>
          <p class="m-card-body">Entwicklung fundierter Gesprächsleitfäden, E-Mail-Sequenzen und Einwandbehandlungen – speziell zugeschnitten auf Zielgruppe und Angebot.</p>
        </div>
        <div class="m-card">
          <div class="m-card-num">03</div>
          <div class="m-card-title">BDR-Onboarding & Skalierung</div>
          <p class="m-card-body">Aufbau eines strukturierten Onboarding-Prozesses zur Verkürzung der Ramp-up-Zeit – von 1 auf 4 BDRs innerhalb von 12 Monaten.</p>
        </div>
        <div class="m-card">
          <div class="m-card-num">04</div>
          <div class="m-card-title">Reporting & Führungsentlastung</div>
          <p class="m-card-body">Wöchentliche Performance-Reviews, laufende Optimierung auf Basis echter Daten – der Geschäftsführer konzentriert sich auf Closing, nicht mehr auf Kaltakquise.</p>
        </div>
      </div>
    </div>

    <!-- Ergebnisse -->
    <div class="ergebnisse-section r">
      <div class="situation-label">Ergebnisse</div>
      <h3 class="situation-h">Phase 1 & Phase 2:<br><em>Beides skaliert.</em></h3>
      <div class="phase-results">
        <div class="phase-card">
          <div class="phase-card-header">
            <div>
              <div class="phase-card-tag">Phase 1 · Erste 12 Monate</div>
              <div class="phase-card-title">Proof of Concept: 1 BDR + Senior-Support</div>
            </div>
          </div>
          <div class="phase-card-body">
            <div class="phase-kpis">
              <div class="pk">
                <div class="pk-val">800 <em>k €</em></div>
                <div class="pk-label">Neukundenumsatz<br>(Front-End)</div>
              </div>
              <div class="pk">
                <div class="pk-val">120</div>
                <div class="pk-label">Qualifizierte<br>Opportunities</div>
              </div>
            </div>
            <ul class="phase-bullets">
              <li class="phase-bullet">Erster externer BDR erfolgreich ongeboardet und produktiv innerhalb von 5 Monaten.</li>
              <li class="phase-bullet">Signifikante Entlastung des Geschäftsführers – erstmals Zeit für strategische Themen.</li>
              <li class="phase-bullet">Vertriebsprozess validiert und für Skalierung vorbereitet.</li>
            </ul>
          </div>
        </div>
        <div class="phase-card">
          <div class="phase-card-header">
            <div>
              <div class="phase-card-tag">Phase 2 · Folgende 12 Monate</div>
              <div class="phase-card-title">Skalierung auf 4 BDRs</div>
            </div>
          </div>
          <div class="phase-card-body">
            <div class="phase-kpis">
              <div class="pk">
                <div class="pk-val">1,4 <em>Mio.</em></div>
                <div class="pk-label">Neukundenumsatz<br>(Front-End)</div>
              </div>
              <div class="pk">
                <div class="pk-val">100 <em>+</em></div>
                <div class="pk-label">Neukunden<br>gewonnen</div>
              </div>
            </div>
            <ul class="phase-bullets">
              <li class="phase-bullet">280 qualifizierte Opportunities über 4 aktive BDRs generiert.</li>
              <li class="phase-bullet">Stabile Ramp-up-Zeit von durchschnittlich 5 Monaten für alle neuen Vertriebler etabliert.</li>
              <li class="phase-bullet">Vollständige Übergabe der Akquise an das Team – Geschäftsführer nicht mehr operativ gebunden.</li>
            </ul>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- QUOTE -->
<div class="case-quote r">
  <div class="case-quote-inner">
    <p class="quote-text">„Wir haben vorher mehrfach versucht, Vertriebsmitarbeiter aufzubauen – jedes Mal ist es gescheitert. Der Unterschied war diesmal die Systematik dahinter: klare Prozesse, klare Kommunikation, klare Verantwortlichkeiten."</p>
    <div class="quote-source"><strong>Geschäftsführer</strong> · B2B-Marketing- und Beratungsagentur</div>
  </div>
</div>

<!-- WEITERE PROJEKTE -->
<section>
  <div class="wrap">
    <div class="r">
      <div class="sec-label">Weitere Projekte</div>
      <h2 class="sec-h">Mehr Branchen,<br><span class="dim">ähnliche Muster.</span></h2>
      <p class="sec-intro">Vertriebsprobleme unterscheiden sich in der Verpackung – die Grundmuster sind branchenübergreifend dieselben. Hier ein Auszug weiterer Projekte.</p>
    </div>
    <div class="weitere-grid">

      <div class="w-card r d1">
        <div class="w-card-bar"></div>
        <div class="w-card-industry">Software & SaaS</div>
        <div class="w-card-title">Vom Founder-Led Sales zum strukturierten Outbound</div>
        <p class="w-card-body">Ein wachsendes Software-Unternehmen generierte neues Geschäft ausschließlich über das Netzwerk des Gründers. Ziel war der Aufbau eines skalierbaren, reproduzierbaren Outbound-Prozesses für die Ansprache von Entscheidern in definierten Zielbranchen – ohne Abhängigkeit vom Founder.</p>
        <div class="w-card-tags">
          <span class="w-tag">ICP-Definition</span>
          <span class="w-tag">Outbound-Struktur</span>
          <span class="w-tag">Entscheiderkontakt</span>
        </div>
      </div>

      <div class="w-card r d2">
        <div class="w-card-bar"></div>
        <div class="w-card-industry">Personaldienstleistung</div>
        <div class="w-card-title">Vertriebsaufbau in der Start-up-Phase</div>
        <p class="w-card-body">Ein junger Personaldienstleister mit solidem Monatsumsatz, aber ohne dedizierte Vertriebsstruktur. Die gesamte Akquise war „Chefsache" ohne System. Aufbau des Sales Playbooks, Kaltansprache-Prozesse und Grundlage für das Onboarding zukünftiger Vertriebler.</p>
        <div class="w-card-tags">
          <span class="w-tag">Sales Playbook</span>
          <span class="w-tag">Kaltakquise</span>
          <span class="w-tag">Prozess-Design</span>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- CTA -->
<div class="cta-strip r">
  <div class="cta-strip-inner">
    <div class="sec-label" style="justify-content:center; margin-bottom:20px;">Nächster Schritt</div>
    <h2 class="cta-h">Ähnliche Ergebnisse<br><em>für Ihr Unternehmen?</em></h2>
    <p class="cta-sub">Jede Zusammenarbeit beginnt mit einem offenen Gespräch. Kein Pitch, keine Präsentation – nur ein ehrliches Gespräch darüber, ob und wie wir helfen können.</p>
    <div class="cta-btns">
      <a href="https://calendar.app.google/9B63foKnMQroLAKM9" target="_blank" rel="noopener" class="btn-primary-inv">Kostenloses Erstgespräch</a>
      <a href="/" class="btn-outline">Zurück zur Website</a>
    </div>
  </div>
</div>

</BaseLayout>

<style>
/* ── PAGE HEADER ── */
.page-header {
  padding: 64px 64px 0;
  background: var(--bg);
  position: relative;
  overflow: hidden;
}

.page-header::before {
  content: '';
  position: absolute; inset: 0;
  background-image: radial-gradient(circle, rgba(107,133,160,0.22) 1px, transparent 1px);
  background-size: 36px 36px;
  pointer-events: none;
}
.page-header::after {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 80% 60% at 100% 0%, rgba(242,245,248,0) 0%, var(--bg) 70%);
  pointer-events: none;
}

.page-header-inner {
  max-width: 1100px; margin: 0 auto;
  padding: 80px 0 100px;
  position: relative; z-index: 1;
}

.ph-label {
  display: inline-flex; align-items: center; gap: 10px;
  font-size: 11px; font-weight: 500;
  letter-spacing: 0.22em; text-transform: uppercase;
  color: var(--slate); margin-bottom: 32px;
  opacity: 0; animation: fadeUp 0.7s 0.1s cubic-bezier(.16,1,.3,1) forwards;
}
.ph-label::before { content: ''; display: block; width: 24px; height: 1px; background: var(--slate-2); }

.ph-h1 {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(48px, 6vw, 80px);
  font-weight: 300; line-height: 1.02;
  letter-spacing: -0.01em; color: var(--navy);
  margin-bottom: 24px;
  opacity: 0; animation: fadeUp 0.8s 0.2s cubic-bezier(.16,1,.3,1) forwards;
}
.ph-h1 em { font-style: italic; color: var(--blue); }

.ph-sub {
  max-width: 540px;
  font-size: 17px; color: var(--text-2);
  line-height: 1.8; font-weight: 300;
  opacity: 0; animation: fadeUp 0.8s 0.35s cubic-bezier(.16,1,.3,1) forwards;
}

/* Stats row in header */
.ph-stats {
  display: flex; gap: 0;
  margin-top: 64px;
  border-top: 1px solid var(--border);
  opacity: 0; animation: fadeUp 0.8s 0.5s cubic-bezier(.16,1,.3,1) forwards;
}
.ph-stat {
  padding: 28px 48px 28px 0;
  border-right: 1px solid var(--border);
  margin-right: 48px;
}
.ph-stat:last-child { border-right: none; margin-right: 0; }
.ph-stat-val {
  font-family: 'Cormorant Garamond', serif;
  font-size: 40px; font-weight: 300;
  color: var(--navy); line-height: 1;
  margin-bottom: 4px; letter-spacing: -0.01em;
}
.ph-stat-val em { font-style: italic; color: var(--blue); font-size: 24px; }
.ph-stat-label { font-size: 12px; color: var(--muted); }

/* ── SHARED ── */
section { padding: 100px 64px; }
section.alt { background: var(--white); }
section.dark { background: var(--navy); }

.wrap { max-width: 1100px; margin: 0 auto; }

.sec-label {
  display: inline-flex; align-items: center; gap: 10px;
  font-size: 10px; font-weight: 500;
  letter-spacing: 0.24em; text-transform: uppercase;
  color: var(--slate); margin-bottom: 20px;
}
.sec-label::after { content: ''; width: 32px; height: 1px; background: var(--border-2); }
section.dark .sec-label { color: rgba(242,245,248,0.35); }
section.dark .sec-label::after { background: rgba(255,255,255,0.1); }

.sec-h {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(32px, 4vw, 52px);
  font-weight: 300; line-height: 1.08;
  letter-spacing: -0.005em; color: var(--navy);
  margin-bottom: 20px;
}
.sec-h em { font-style: italic; color: var(--blue); }
.sec-h .dim { color: var(--slate); }
section.dark .sec-h { color: var(--white); }

.sec-intro {
  font-size: 16px; color: var(--text-2);
  line-height: 1.85; max-width: 560px;
  margin-bottom: 56px; font-weight: 300;
}
section.dark .sec-intro { color: rgba(242,245,248,0.5); }

/* Reveal */
.r { opacity: 0; transform: translateY(22px); transition: opacity 0.7s cubic-bezier(.16,1,.3,1), transform 0.7s cubic-bezier(.16,1,.3,1); }
.r.in { opacity: 1; transform: translateY(0); }
.d1 { transition-delay: 0.1s; }
.d2 { transition-delay: 0.2s; }
.d3 { transition-delay: 0.3s; }
.d4 { transition-delay: 0.4s; }
.d5 { transition-delay: 0.5s; }

/* ── FEATURED CASE ── */
.case-intro-band {
  background: var(--navy);
  padding: 0 64px;
}
.case-intro-inner {
  max-width: 1100px; margin: 0 auto;
  display: grid; grid-template-columns: 1fr 1fr;
  border-left: 1px solid rgba(255,255,255,0.06);
  border-right: 1px solid rgba(255,255,255,0.06);
}
.case-intro-left {
  padding: 72px 56px 72px 0;
  border-right: 1px solid rgba(255,255,255,0.08);
}
.case-intro-right {
  padding: 72px 0 72px 56px;
  display: flex; flex-direction: column; justify-content: center;
}

.case-tag {
  display: inline-flex; align-items: center; gap: 8px;
  font-size: 10px; font-weight: 500;
  letter-spacing: 0.2em; text-transform: uppercase;
  color: var(--slate-2); margin-bottom: 20px;
}
.case-tag-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--blue-mid);
}

.case-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(28px, 3.5vw, 44px);
  font-weight: 300; line-height: 1.1;
  color: var(--white); letter-spacing: -0.01em;
  margin-bottom: 20px;
}
.case-name em { font-style: italic; color: var(--slate-2); }

.case-desc {
  font-size: 15px; color: rgba(242,245,248,0.5);
  line-height: 1.8; font-weight: 300;
}

.kpi-grid-dark {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 1px; background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.06);
}
.kd {
  background: rgba(255,255,255,0.03);
  padding: 28px 24px; text-align: center;
}
.kd-val {
  font-family: 'Cormorant Garamond', serif;
  font-size: 38px; font-weight: 300;
  color: var(--white); line-height: 1; margin-bottom: 6px;
  letter-spacing: -0.02em;
}
.kd-val em { font-style: italic; color: var(--slate-2); font-size: 22px; }
.kd-label { font-size: 12px; color: rgba(242,245,248,0.4); line-height: 1.4; }

/* ── CASE BODY ── */
.case-body-section {
  padding: 100px 64px;
  background: var(--white);
}
.case-body-inner { max-width: 1100px; margin: 0 auto; }

/* Challenge / Situation */
.situation-layout {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 64px; margin-bottom: 80px;
  padding-bottom: 80px;
  border-bottom: 1px solid var(--border);
}

.situation-label {
  font-size: 10px; font-weight: 500;
  letter-spacing: 0.22em; text-transform: uppercase;
  color: var(--slate); margin-bottom: 16px;
  display: flex; align-items: center; gap: 10px;
}
.situation-label::after { content: ''; width: 24px; height: 1px; background: var(--border-2); }

.situation-h {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(26px, 3vw, 38px);
  font-weight: 300; line-height: 1.15;
  color: var(--navy); letter-spacing: -0.01em;
  margin-bottom: 20px;
}
.situation-h em { font-style: italic; color: var(--blue); }

.situation-body {
  font-size: 15px; color: var(--text-2);
  line-height: 1.85; font-weight: 300;
}

.challenge-list {
  list-style: none;
  display: flex; flex-direction: column; gap: 12px;
  margin-top: 8px;
}
.challenge-item {
  display: flex; gap: 16px;
  align-items: flex-start;
  font-size: 14px; color: var(--text-2); line-height: 1.7;
}
.challenge-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 18px; font-weight: 300;
  color: var(--slate-2); flex-shrink: 0;
  width: 28px; padding-top: 1px;
}

/* Massnahmen */
.massnahmen-section { margin-bottom: 80px; padding-bottom: 80px; border-bottom: 1px solid var(--border); }

.massnahmen-grid {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 1px; background: var(--border);
  border: 1px solid var(--border);
  margin-top: 8px;
}
.m-card {
  background: var(--white);
  padding: 36px 32px;
  position: relative; overflow: hidden;
  transition: background 0.25s;
}
.m-card:hover { background: var(--bg); }
.m-card::before {
  content: '';
  position: absolute; left: 0; top: 0; bottom: 0;
  width: 0; background: var(--blue);
  transition: width 0.35s cubic-bezier(.16,1,.3,1);
}
.m-card:hover::before { width: 2px; }

.m-card-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 42px; font-weight: 300;
  color: rgba(107,133,160,0.18); line-height: 1; margin-bottom: 16px;
}
.m-card-title {
  font-size: 15px; font-weight: 500;
  color: var(--navy); margin-bottom: 10px;
  letter-spacing: -0.01em; line-height: 1.35;
}
.m-card-body { font-size: 13.5px; color: var(--text-2); line-height: 1.75; }

/* Ergebnisse */
.ergebnisse-section { }

.phase-results {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 24px;
}

.phase-card {
  border: 1px solid var(--border);
  overflow: hidden;
}

.phase-card-header {
  background: var(--navy);
  padding: 24px 32px;
  display: flex; align-items: center; gap: 16px;
}
.phase-card-tag {
  font-size: 10px; font-weight: 500;
  letter-spacing: 0.18em; text-transform: uppercase;
  color: rgba(242,245,248,0.4);
}
.phase-card-title {
  font-size: 15px; font-weight: 500;
  color: var(--white);
}

.phase-card-body { padding: 32px; background: var(--bg); }

.phase-kpis {
  display: grid; grid-template-columns: 1fr 1fr;
